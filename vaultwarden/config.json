{
  "arch": [
    "amd64",
    "aarch64"
  ],
  "boot": "auto",
  "description": "用Rust编写、与上游Bitwarden客户端*兼容的Bitwarden服务器API的替代实现，非常适合自托管部署，因为运行官方的资源密集型服务可能不太理想",
  "environment": {
    "DATA_FOLDER": "/config"
  },
  "map": [
    "addon_config:rw"
  ],
  "image": "ghcr.nju.edu.cn/dani-garcia/vaultwarden",
  "version": "1.34.2",
  "name": "Vaultwarden",
  "options": {},
  "ports": {
    "80/tcp": "7277"
  },
  "ports_description": {
    "80/tcp": "Web interface"
  },
  "schema": {},
  "slug": "vaultwarden",
  "startup": "services",
  "upstream": "1.34.2",
  "url": "https://ghfast.top/github.com/jdeath/homeassistant-addons",
  "webui": "[PROTO:ssl]://[HOST]:[PORT:80]",
  "ingress": true,
  "ingress_port": 80
}
